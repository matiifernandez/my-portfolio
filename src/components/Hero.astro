---
// Hero: The most important section - first impression
// Minimalist but impactful design with a subtle gradient
---

<section class="relative min-h-[85dvh] flex items-center justify-center overflow-hidden">
  <!--
    min-h-[85dvh]: Minimum height of 85% of the dynamic viewport
    dvh adapts better to mobile where the browser bar can appear/disappear
    We use 85% instead of 100% so that it's visible that there's more content below
  -->

  <!-- Subtle background gradient - makes the section more interesting -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 via-transparent to-cyan-500/5"
  >
    <!--
      from-emerald-500/5: Initial color with 5% opacity (very subtle)
      via-transparent: Transparent in the middle
      to-cyan-500/5: Final color with 5% opacity

      The /5 means 5% opacity - this creates an elegant effect without being invasive
    -->
  </div>

  <!-- Decorative background grid with mask to fade it downwards -->
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(52,211,153,0.07)_1px,transparent_1px),linear-gradient(90deg,rgba(52,211,153,0.07)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:linear-gradient(to_bottom,white_50%,transparent_100%)]"
  >
    <!--
      This creates a grid pattern using CSS gradients
      The mask-image fades the grid downwards for a more elegant effect
    -->
  </div>

  <!-- Main content -->
  <div class="relative z-10 mx-auto max-w-4xl px-6 text-center">
    <!-- Location badge -->
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/50 px-4 py-2 text-sm text-zinc-400">
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
      </span>
      Based in Tokyo, Japan
    </div>
    <!--
      The flashing dot indicates "available/active"
      animate-ping is a built-in Tailwind animation
      The badge gives immediate context about your location
    -->

    <!-- Main title -->
    <h1 class="mb-6 text-5xl font-bold tracking-tight sm:text-6xl lg:text-7xl">
      <!--
        Responsive sizes:
        text-5xl: Mobile (default)
        sm:text-6xl: Tablets (640px+)
        lg:text-7xl: Desktop (1024px+)
      -->
      Hi, I'm
      <span class="bg-gradient-to-r from-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        Matias
      </span>
      <!--
        bg-clip-text + text-transparent:
        This makes the gradient apply to the TEXT instead of the background
        It's the "gradient text" effect you see on modern sites
      -->
    </h1>

    <!-- Subtitle with typewriter effect -->
    <p class="mx-auto mb-8 max-w-2xl text-lg text-zinc-400 sm:text-xl">
      Full Stack web developer. <span id="typewriter" class="text-emerald-400"></span><span class="animate-pulse">|</span> things.
      <br class="hidden sm:block" />
      Mate 🧉, code, and a bit of chaos.
    </p>

    <!-- CTAs (Call to Action) -->
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#projects"
        class="group inline-flex items-center gap-2 rounded-lg bg-emerald-500 px-6 py-3 font-medium text-zinc-950 transition-all hover:bg-emerald-400 hover:shadow-lg hover:shadow-emerald-500/25"
      >
        <!--
          group: Allows children to react to the parent's hover
          shadow-emerald-500/25: Shadow with the button's color (glow effect)
        -->
        View my work
        <svg
          class="h-4 w-4 transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
        <!--
          group-hover:translate-x-1: The arrow moves when you hover over the button
          Small animation that gives visual feedback
        -->
      </a>

      {[
        { href: "#contact", label: "Get in touch" },
        { href: "#about", label: "About me" }
      ].map(({ href, label }) => (
        <a
          href={href}
          class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 px-6 py-3 font-medium text-zinc-300 transition-all hover:border-zinc-600 hover:bg-zinc-800/50"
        >
          {label}
        </a>
      ))}
    </div>

  </div>

  <!-- Clickable scroll indicator - takes you to the next viewport -->
  <a
    href="#projects"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce cursor-pointer transition-colors hover:text-emerald-400"
    aria-label="Scroll to projects"
  >
    <svg class="h-6 w-6 text-zinc-600 hover:text-emerald-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </a>
</section>
