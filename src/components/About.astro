---
// About Section - Your story and skills
// Asymmetrical design to make it more visually interesting

const skills = {
  languages: ["Ruby", "JavaScript", "HTML", "CSS", "SQL"],
  frameworks: ["Ruby on Rails", "Stimulus", "Tailwind CSS", "Bootstrap"],
  tools: ["Git", "GitHub", "PostgreSQL", "VS Code", "Figma"],
  learning: ["Python (Django)", "React"]
};
---

<section id="about" class="py-24">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Asymmetrical grid: text larger than skills -->
    <div class="grid gap-12 lg:grid-cols-5">
      <!--
        lg:grid-cols-5: 5 columns on large screens
        This allows us to make a 3:2 distribution (more flexible than 2 equal columns)
      -->

      <!-- Main text: occupies 3 columns -->
      <div class="lg:col-span-3 animate-on-scroll">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          About me
        </h2>

        <!-- Code snippet style -->
        <div class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
          <!-- Editor-like top bar -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-zinc-800 bg-zinc-900/80">
            <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
            <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
            <span class="h-3 w-3 rounded-full bg-zinc-700"></span>
            <span class="ml-2 text-xs text-zinc-500">about.js</span>
          </div>

          <!-- Code -->
          <div class="p-4 font-mono text-sm leading-relaxed overflow-x-auto">
            <p><span class="text-zinc-500">const</span> <span class="text-emerald-400">matias</span> <span class="text-zinc-500">=</span> <span class="text-zinc-400">{</span></p>
            <p class="pl-4"><span class="text-cyan-400">location</span><span class="text-zinc-500">:</span> <span class="text-amber-300">"Tokyo, Japan"</span><span class="text-zinc-500">,</span></p>
            <p class="pl-4"><span class="text-cyan-400">path</span><span class="text-zinc-500">:</span> <span class="text-amber-300">"Argentina → Australia → Japan"</span><span class="text-zinc-500">,</span></p>
            <p class="pl-4"><span class="text-cyan-400">currently</span><span class="text-zinc-500">:</span> <span class="text-amber-300">"Le Wagon bootcamp graduate"</span><span class="text-zinc-500">,</span></p>
            <p class="pl-4"><span class="text-cyan-400">languages</span><span class="text-zinc-500">:</span> <span class="text-zinc-400">[</span><span class="text-amber-300">"ES"</span><span class="text-zinc-500">,</span> <span class="text-amber-300">"EN"</span><span class="text-zinc-500">,</span> <span class="text-amber-300">"日本語勉強中"</span><span class="text-zinc-400">]</span><span class="text-zinc-500">,</span></p>
            <p class="pl-4"><span class="text-cyan-400">hobbies</span><span class="text-zinc-500">:</span> <span class="text-zinc-400">[</span><span class="text-amber-300">"mate 🧉"</span><span class="text-zinc-500">,</span> <span class="text-amber-300">"debugging 💻"</span><span class="text-zinc-500">,</span> <span class="text-amber-300">"exploring Tokyo 🏯"</span><span class="text-zinc-400">]</span></p>
            <p><span class="text-zinc-400">}</span><span class="text-zinc-500">;</span></p>
          </div>
        </div>
      </div>

      <!-- Skills: occupies 2 columns -->
      <div class="lg:col-span-2 animate-on-scroll delay-200">
        <div class="rounded-2xl border border-zinc-800 bg-zinc-900/30 p-6">
          <h3 class="mb-6 text-lg font-semibold text-zinc-200">Tech Stack</h3>

          <div class="space-y-6">
            <!-- Languages -->
            <div>
              <h4 class="mb-3 text-xs font-medium uppercase tracking-wider text-zinc-500">
                Languages
              </h4>
              <div class="flex flex-wrap gap-2">
                {skills.languages.map((skill) => (
                  <span class="rounded-lg bg-zinc-800 px-3 py-1.5 text-sm text-zinc-300">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            <!-- Frameworks -->
            <div>
              <h4 class="mb-3 text-xs font-medium uppercase tracking-wider text-zinc-500">
                Frameworks
              </h4>
              <div class="flex flex-wrap gap-2">
                {skills.frameworks.map((skill) => (
                  <span class="rounded-lg bg-zinc-800 px-3 py-1.5 text-sm text-zinc-300">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            <!-- Tools -->
            <div>
              <h4 class="mb-3 text-xs font-medium uppercase tracking-wider text-zinc-500">
                Tools
              </h4>
              <div class="flex flex-wrap gap-2">
                {skills.tools.map((skill) => (
                  <span class="rounded-lg bg-zinc-800 px-3 py-1.5 text-sm text-zinc-300">
                    {skill}
                  </span>
                ))}
              </div>
            </div>

            <!-- Learning -->
            <div>
              <h4 class="mb-3 text-xs font-medium uppercase tracking-wider text-zinc-500">
                Currently Learning
              </h4>
              <div class="flex flex-wrap gap-2">
                {skills.learning.map((skill) => (
                  <span class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5 text-sm text-emerald-400">
                    {skill}
                  </span>
                ))}
                <!--
                  Learning skills have a different style (green)
                  This distinguishes them visually and shows you're still learning
                -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
