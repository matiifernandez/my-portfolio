---
// El Header es fixed (se queda arriba) y tiene un efecto de glassmorphism
// cuando haces scroll. Esto lo haremos con vanilla JS más adelante.
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
>
  <nav class="mx-auto max-w-5xl px-6 py-4 flex items-center justify-between">
    <!--
      max-w-5xl: Ancho máximo contenido (no queremos que se expanda en pantallas gigantes)
      mx-auto: Centra el contenido
      px-6: Padding horizontal (espaciado a los lados)
      py-4: Padding vertical
    -->

    <!-- Logo/Nombre -->
    <a
      href="#"
      class="text-xl font-bold tracking-tight hover:text-emerald-400 transition-colors"
    >
      <!--
        tracking-tight: Reduce el espaciado entre letras (más compacto, moderno)
        hover:text-emerald-400: Color al pasar el mouse
        transition-colors: Animación suave del cambio de color
      -->
      mf<span class="text-emerald-400">.</span>
      <!--
        El punto verde es un detalle simple pero memorable
        Hace que el logo sea reconocible
      -->
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-8">
      <li>
        <a
          href="#projects"
          class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
        >
          Projects
        </a>
      </li>
      <li>
        <a
          href="#about"
          class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
        >
          About
        </a>
      </li>
      <li>
        <a
          href="#contact"
          class="text-sm text-zinc-400 hover:text-zinc-100 transition-colors"
        >
          Contact
        </a>
      </li>
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="menu-toggle"
      class="block md:hidden text-zinc-400 hover:text-zinc-100 transition-colors p-2"
      aria-label="Toggle Menu"
    >
      <svg
        id="menu-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
        />
      </svg>
      <svg
        id="close-icon"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="w-6 h-6 hidden"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M6 18L18 6M6 6l12 12"
        />
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-[72px] bg-zinc-950/95 backdrop-blur-md z-40 hidden flex-col items-center justify-center gap-8 md:hidden transition-all duration-300 border-t border-zinc-800/50"
  >
    <a
      href="#projects"
      class="text-2xl font-medium text-zinc-400 hover:text-zinc-100 transition-colors mobile-link"
    >
      Projects
    </a>
    <a
      href="#about"
      class="text-2xl font-medium text-zinc-400 hover:text-zinc-100 transition-colors mobile-link"
    >
      About
    </a>
    <a
      href="#contact"
      class="text-2xl font-medium text-zinc-400 hover:text-zinc-100 transition-colors mobile-link"
    >
      Contact
    </a>
  </div>
</header>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  function toggleMenu() {
    mobileMenu?.classList.toggle('hidden');
    mobileMenu?.classList.toggle('flex');
    menuIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
    document.body.classList.toggle('overflow-hidden');
  }

  menuToggle?.addEventListener('click', toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (!mobileMenu?.classList.contains('hidden')) {
        toggleMenu();
      }
    });
  });
</script>

<!-- Spacer para compensar el header fixed -->
<div class="h-16"></div>
