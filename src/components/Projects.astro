---
// Projects Section
// Here we import and use the ProjectCard component

import ProjectCard from './ProjectCard.astro';

// Define projects as data
// This is like having an array of objects that you iterate with .each in Rails
// UPDATE THIS with your actual projects
const projects = [
  {
    title: "Kizuna Lingua",
    description: "Kizuna Lingua is an innovative language learning platform for couples that leverages AI to create personalized study plans and interactive exercises. Built with Ruby on Rails and PostgreSQL, it integrates advanced language models to provide real-time feedback and conversational practice. Kizuna Lingua aims to make language learning engaging and effective for users of all levels.",
    tags: ["Ruby on Rails", "PostgreSQL", "Stimulus", "Ruby LLM Integration"],
    image: "/images/kizuna-lingua.png",
    demoUrl: "https://www.kizunalingua.com/",
    repoUrl: "https://github.com/matiifernandez/kizuna-lingua",
    featured: true
  },
  {
    title: "Che Market",
    description: "A full-stack e-commerce platform for Argentine products worldwide. Features include product management, categories, orders, coupons, gift cards, reviews, and a complete admin dashboard with real-time updates. Built with Rails 7, Hotwire (Turbo & Stimulus), and Tailwind CSS for a modern, responsive experience.",
    tags: ["Ruby on Rails 7", "Hotwire", "Tailwind CSS", "PostgreSQL", "E-commerce"],
    image: "/images/che-market.png",
    demoUrl: "https://che-market.onrender.com/",
    repoUrl: "https://github.com/matiifernandez/che_market",
    featured: true
  },
  {
    title: "UI Forge",
    description: "UI Forge is an AI-powered design assistant that helps you create stunning layouts. Built with Ruby on Rails and integrated with advanced language models, UI Forge allows users to generate design components and styles through simple text prompts. Whether you're a developer looking to speed up your design process or a designer seeking inspiration, UI Forge provides a seamless experience to bring your ideas to life.",
    tags: ["Ruby on Rails", "Ruby LLM Integration", "JavaScript", "APIs", "CSS"],
    image: "/images/ui-forge.png",
    demoUrl: "https://ai-assistant-matiifernandez-132f8eab454e.herokuapp.com/",
    repoUrl: "https://github.com/matiifernandez/ui-forge-v2",
    featured: false
  },
  {
    title: "Code Editor",
    description: "A simple online code editor supporting HTML, CSS, and JavaScript with live preview. Built with vanilla JavaScript, it provides a clean interface for writing and testing code snippets directly in the browser.",
    tags: ["JavaScript", "HTML", "CSS"],
    image: "/images/code-editor.png",
    demoUrl: "https://online-js-editor.netlify.app/",
    repoUrl: "https://github.com/matiifernandez/code-editor",
    featured: false
  },
  {
    title: "Vanilla JS Tic-Tac-Toe",
    description: "Tic-Tac-Toe with localStorage persistence and multi-tab sync. Built with vanilla JS using MVC pattern.",
    tags: ["JavaScript", "HTML", "CSS", "MVC"],
    image: "/images/tictactoe.png",
    demoUrl: "https://vanillajs-tic-tac-toe.netlify.app/",
    repoUrl: "https://github.com/matiifernandez/vanilla-tictactoe",
    featured: false
  },
  // Add more projects here when you have them
];
---

<section id="projects" class="py-24">
  <!--
    py-24: Generous vertical padding (96px)
    This gives "room to breathe" between sections
  -->

  <div class="mx-auto max-w-5xl px-6">
    <!-- Section Header -->
    <div class="mb-12 text-center animate-on-scroll">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
        Featured Projects
      </h2>
      <p class="mt-4 text-zinc-400">
        My Learning Journey Through Projects.
      </p>
    </div>

    <!-- Project grid -->
    <div class="grid gap-6 md:grid-cols-2 animate-on-scroll delay-200">
      <!--
        grid: Activates CSS Grid
        gap-6: Space between items
        md:grid-cols-2: 2 columns on medium screens+

        "featured" projects occupy 2 columns (defined in ProjectCard)
      -->
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
      <!--
        {...project} is spread syntax
        It passes all object attributes as individual props
        Equivalent to: title={project.title} description={project.description} etc.
      -->
    </div>
  </div>
</section>
